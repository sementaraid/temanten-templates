# CDN / S3 deployment
CDN_BUCKET=your-s3-bucket-name
CDN_BASE_URL=https://cdn.temanten.com
REGISTRY_URL=https://cdn.temanten.com/templates/registry.json

# AWS / CloudFront credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=          # leave blank for AWS S3; set for Cloudflare R2
AWS_DEFAULT_REGION=auto
VITE_CDN_DISTRIBUTION_ID=  # CloudFront distribution ID for cache invalidation
